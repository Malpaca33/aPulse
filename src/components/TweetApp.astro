                ></textarea>
              </label>

              <div class="mt-4 flex flex-col gap-3 border-t border-slate-200 pt-4 dark:border-slate-800 sm:flex-row sm:items-center sm:justify-between">
                <p id="composer-status" class="text-sm text-slate-500 dark:text-slate-400">Publish up to 280 characters.</p>
                <button
                  id="tweet-submit"
                  type="submit"
                  class="rounded-full bg-sky-500 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-sky-600 disabled:cursor-not-allowed disabled:bg-slate-300 dark:disabled:bg-slate-700"
                >
                  Post
                </button>
              </div>
            </form>
          </div>
        </div>
      </section>

      <div class="border-b border-slate-200/90 px-4 py-3 text-sm text-slate-500 dark:border-slate-800 dark:text-slate-400 sm:px-6">
        <p id="feed-status">Loading latest tweets...</p>
      </div>

      <div id="feed-list" class="divide-y divide-slate-200 dark:divide-slate-800"></div>
    </main>

    <aside class="hidden px-6 py-6 xl:block">
      <div class="sticky top-0 space-y-5">
        <div class="rounded-[1.75rem] bg-slate-100/90 p-4 dark:bg-slate-950">
          <label class="flex items-center gap-3 rounded-full bg-white px-4 py-3 text-sm text-slate-500 shadow-sm ring-1 ring-slate-200 dark:bg-black dark:text-slate-400 dark:ring-slate-800">
            <span class="text-base">#</span>
            <input
              type="search"
              placeholder="Search"
              class="w-full border-0 bg-transparent p-0 text-sm text-slate-900 outline-none placeholder:text-slate-400 focus:ring-0 dark:text-white dark:placeholder:text-slate-500"
            />
          </label>
        </div>

        <section class="rounded-[1.75rem] bg-slate-100/90 p-5 dark:bg-slate-950">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-[0.3em] text-sky-600 dark:text-sky-400">For You</p>
              <h2 class="mt-1 text-xl font-bold text-slate-950 dark:text-white">Trends</h2>
            </div>
            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600 shadow-sm dark:bg-black dark:text-slate-300">Live</span>
          </div>
          <div class="mt-4 space-y-2">
            <article class="rounded-2xl border border-slate-200 bg-white p-4 transition hover:border-slate-300 dark:border-slate-800 dark:bg-black dark:hover:border-slate-700">
              <p class="text-xs uppercase tracking-[0.25em] text-slate-400">AI builders</p>
              <h3 class="mt-2 text-sm font-semibold text-slate-950 dark:text-white">Astro + Supabase shipping logs</h3>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">12.4K posts</p>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-4 transition hover:border-slate-300 dark:border-slate-800 dark:bg-black dark:hover:border-slate-700">
              <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Design systems</p>
              <h3 class="mt-2 text-sm font-semibold text-slate-950 dark:text-white">Minimal social interfaces</h3>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">8.1K posts</p>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-4 transition hover:border-slate-300 dark:border-slate-800 dark:bg-black dark:hover:border-slate-700">
              <p class="text-xs uppercase tracking-[0.25em] text-slate-400">Realtime</p>
              <h3 class="mt-2 text-sm font-semibold text-slate-950 dark:text-white">Postgres changes in production</h3>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">5.9K posts</p>
            </article>
          </div>
        </section>
      </div>
    </aside>
  </div>
</section>

<script type="module">
  import { createBrowserSupabase } from '../lib/supabase.js';

  const supabase = createBrowserSupabase();
  const feedList = document.querySelector('#feed-list');
  const feedStatus = document.querySelector('#feed-status');
  const authStatus = document.querySelector('#auth-status');
  const composerHint = document.querySelector('#composer-hint');
  const composerStatus = document.querySelector('#composer-status');
  const tweetForm = document.querySelector('#tweet-form');
  const tweetContent = document.querySelector('#tweet-content');
  const tweetSubmit = document.querySelector('#tweet-submit');
  const charCount = document.querySelector('#char-count');
  const refreshFeedButton = document.querySelector('#refresh-feed');
  const githubLoginButton = document.querySelector('#github-login');
  const anonLoginButton = document.querySelector('#anon-login');
  const signOutButton = document.querySelector('#sign-out');
  const relativeTimeFormatter = new Intl.RelativeTimeFormat('zh-CN', { numeric: 'auto' });

  let currentSession = null;
  let feedRequestInFlight = false;

  function escapeHtml(value) {
    return String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function formatIdentity(session) {
    const user = session?.user;

    if (!user) {
      return 'Not signed in';
    }

    if (user.app_metadata?.provider === 'github') {
      return user.user_metadata?.user_name || user.user_metadata?.preferred_username || user.email || 'GitHub user';
    }

    if (user.is_anonymous) {
      return `Anonymous ${user.id.slice(0, 8)}`;
    }

    return user.email || user.id.slice(0, 8);
  }

  function formatAuthor(tweet) {
    if (currentSession?.user?.id === tweet.user_id) {
      return 'You';
    }

    return `User ${tweet.user_id.slice(0, 8)}`;
  }

  function formatRelativeTime(value) {
    const now = Date.now();
    const target = new Date(value).getTime();
    const diffSeconds = Math.round((target - now) / 1000);
    const ranges = [
      { unit: 'year', seconds: 31536000 },
      { unit: 'month', seconds: 2592000 },
      { unit: 'week', seconds: 604800 },
      { unit: 'day', seconds: 86400 },
      { unit: 'hour', seconds: 3600 },
      { unit: 'minute', seconds: 60 },
      { unit: 'second', seconds: 1 },
    ];

    for (const range of ranges) {
      if (Math.abs(diffSeconds) >= range.seconds || range.unit === 'second') {
        return relativeTimeFormatter.format(Math.round(diffSeconds / range.seconds), range.unit);
      }
    }

    return 'just now';
  }

  function setComposerEnabled(enabled) {
    tweetContent.disabled = !enabled;
    composerHint.textContent = enabled ? `Posting as ${formatIdentity(currentSession)}` : 'Login required';
  }

  function updateSubmitState() {
    const content = tweetContent.value.trim();
    const isOverLimit = content.length > 280;
    const isEmpty = content.length === 0;

    charCount.textContent = `${content.length} / 280`;
    charCount.className = isOverLimit
      ? 'rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-600 dark:bg-rose-950/60 dark:text-rose-300'
      : 'rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-500 dark:bg-slate-900 dark:text-slate-300';

    if (isOverLimit) {
      composerStatus.textContent = 'Tweet content must be 280 characters or fewer.';
    } else if (isEmpty) {
      composerStatus.textContent = 'Publish up to 280 characters.';
    } else {
      composerStatus.textContent = 'Ready to post.';
    }

    tweetSubmit.disabled = !currentSession || isEmpty || isOverLimit;
  }

  function renderAuth() {
    authStatus.innerHTML = currentSession
      ? `
        <p class="text-base font-semibold text-slate-950 dark:text-white">${escapeHtml(formatIdentity(currentSession))}</p>
        <p class="text-sm text-slate-500 dark:text-slate-400">${escapeHtml(currentSession.user.id)}</p>
      `
      : `
        <p class="text-base font-semibold text-slate-950 dark:text-white">Visitor mode</p>
        <p class="text-sm text-slate-500 dark:text-slate-400">Read the feed or sign in to publish and like.</p>
      `;

    githubLoginButton.classList.toggle('hidden', Boolean(currentSession));
    anonLoginButton.classList.toggle('hidden', Boolean(currentSession));
    signOutButton.classList.toggle('hidden', !currentSession);
    setComposerEnabled(Boolean(currentSession));
    updateSubmitState();
  }

  function renderTweets(tweets) {
    if (!tweets.length) {
      feedList.innerHTML = `
        <article class="px-4 py-12 text-center sm:px-6">
          <div class="rounded-[1.5rem] border border-dashed border-slate-300 bg-white px-6 py-10 text-slate-500 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-400">
            No tweets yet. Publish the first one.
          </div>
        </article>
      `;
      return;
    }

    feedList.innerHTML = tweets
      .map(
        (tweet) => `
          <article class="group px-4 py-4 transition hover:bg-slate-50 dark:hover:bg-slate-950/60 sm:px-6">
            <div class="rounded-[1.5rem] border border-slate-200 bg-white p-5 transition group-hover:border-slate-300 dark:border-slate-800 dark:bg-black dark:group-hover:border-slate-700">
              <div class="flex items-start gap-3">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-slate-100 text-sm font-bold text-slate-700 dark:bg-slate-900 dark:text-slate-200">
                  ${escapeHtml(formatAuthor(tweet).slice(0, 2).toUpperCase())}
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                    <p class="text-sm font-semibold text-slate-950 dark:text-white">${escapeHtml(formatAuthor(tweet))}</p>
                    <span class="text-sm text-slate-400 dark:text-slate-500">·</span>
                    <p class="text-sm text-slate-500 dark:text-slate-400">${escapeHtml(formatRelativeTime(tweet.created_at))}</p>
                  </div>
                  <p class="mt-3 whitespace-pre-wrap text-[15px] leading-7 text-slate-700 dark:text-slate-200">${escapeHtml(tweet.content)}</p>
                  <div class="mt-5 flex items-center justify-between">
                    <span class="text-xs uppercase tracking-[0.22em] text-slate-400 dark:text-slate-500">Realtime feed</span>
                    <button
                      type="button"
                      data-like-id="${tweet.id}"
                      class="like-button inline-flex items-center gap-2 rounded-full border px-4 py-2 text-sm font-semibold transition ${
                        tweet.viewer_has_liked
                          ? 'border-rose-200 bg-rose-50 text-rose-600 hover:bg-rose-100 dark:border-rose-900 dark:bg-rose-950/40 dark:text-rose-300 dark:hover:bg-rose-950/60'
                          : 'border-slate-200 bg-white text-slate-600 hover:border-slate-300 hover:bg-slate-50 dark:border-slate-800 dark:bg-black dark:text-slate-300 dark:hover:border-slate-700 dark:hover:bg-slate-950'
                      }"
                      ${currentSession ? '' : 'disabled'}
                    >
                      <span aria-hidden="true">${tweet.viewer_has_liked ? '♥' : '♡'}</span>
                      <span>${tweet.likes_count}</span>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </article>
        `,
      )
      .join('');
  }

  async function getAccessToken() {
    const { data } = await supabase.auth.getSession();
    return data.session?.access_token ?? null;
  }

  async function fetchTweets({ silent = false } = {}) {
    if (feedRequestInFlight) {
      return;
    }

    feedRequestInFlight = true;

    if (!silent) {
      feedStatus.textContent = 'Refreshing feed...';
    }

    try {
      const accessToken = await getAccessToken();
      const response = await fetch('/api/tweets', {
        headers: accessToken
          ? {
              Authorization: `Bearer ${accessToken}`,
            }
          : {},
      });
      const payload = await response.json();

      if (!response.ok) {
        throw new Error(payload.error || 'Failed to load tweets.');
      }

      renderTweets(payload.tweets);
      feedStatus.textContent = `Updated ${formatRelativeTime(new Date().toISOString())}`;
    } catch (error) {
      feedStatus.textContent = error.message;
    } finally {
      feedRequestInFlight = false;
    }
  }

  async function submitTweet(event) {
    event.preventDefault();

    const content = tweetContent.value.trim();

    if (!content) {
      composerStatus.textContent = 'Write something before publishing.';
      return;
    }

    if (content.length > 280) {
      composerStatus.textContent = 'Tweet content must be 280 characters or fewer.';
      updateSubmitState();
      return;
    }

    tweetSubmit.disabled = true;
    composerStatus.textContent = 'Publishing...';

    try {
      const accessToken = await getAccessToken();

      if (!accessToken) {
        throw new Error('Authentication required.');
      }

      const response = await fetch('/api/tweets', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${accessToken}`,
        },
        body: JSON.stringify({ content }),
      });
      const payload = await response.json();

      if (!response.ok) {
        throw new Error(payload.error || 'Failed to publish tweet.');
      }

      tweetContent.value = '';
      composerStatus.textContent = 'Tweet published.';
      updateSubmitState();
      await fetchTweets({ silent: true });
    } catch (error) {
      composerStatus.textContent = error.message;
    } finally {
      updateSubmitState();
    }
  }

  async function toggleLike(tweetId, button) {
    if (!currentSession) {
      feedStatus.textContent = 'Login required to like tweets.';
      return;
    }

    button.disabled = true;

    try {
      const accessToken = await getAccessToken();

      if (!accessToken) {
        throw new Error('Authentication required.');
      }

      const response = await fetch(`/api/tweets/${tweetId}/like`, {
        method: 'POST',
        headers: {
          Authorization: `Bearer ${accessToken}`,
        },
      });
      const payload = await response.json();

      if (!response.ok) {
        throw new Error(payload.error || 'Failed to update like.');
      }

      button.classList.add('like-burst');
      window.setTimeout(() => button.classList.remove('like-burst'), 360);
      await fetchTweets({ silent: true });
    } catch (error) {
      feedStatus.textContent = error.message;
    } finally {
      button.disabled = false;
    }
  }

  async function signInWithGitHub() {
    const redirectTo = new URL(window.location.href);
    const { error } = await supabase.auth.signInWithOAuth({
      provider: 'github',
      options: {
        redirectTo: redirectTo.toString(),
      },
    });

    if (error) {
      authStatus.innerHTML = `<p class="text-sm text-rose-500 dark:text-rose-300">${escapeHtml(error.message)}</p>`;
    }
  }

  async function signInAnonymously() {
    const { error } = await supabase.auth.signInAnonymously();

    if (error) {
      authStatus.innerHTML = `<p class="text-sm text-rose-500 dark:text-rose-300">${escapeHtml(error.message)}</p>`;
    }
  }

  async function signOut() {
    const { error } = await supabase.auth.signOut({ scope: 'local' });

    if (error) {
      authStatus.innerHTML = `<p class="text-sm text-rose-500 dark:text-rose-300">${escapeHtml(error.message)}</p>`;
      return;
    }

    composerStatus.textContent = 'Signed out.';
  }

  function mountRealtime() {
    supabase
      .channel('tweet-feed')
      .on('postgres_changes', { event: '*', schema: 'public', table: 'tweets' }, () => {
        fetchTweets({ silent: true });
      })
      .on('postgres_changes', { event: '*', schema: 'public', table: 'tweet_likes' }, () => {
        fetchTweets({ silent: true });
      })
      .subscribe();
  }

  tweetForm.addEventListener('submit', submitTweet);
  tweetContent.addEventListener('input', updateSubmitState);
  refreshFeedButton.addEventListener('click', () => fetchTweets());
  githubLoginButton.addEventListener('click', signInWithGitHub);
  anonLoginButton.addEventListener('click', signInAnonymously);
  signOutButton.addEventListener('click', signOut);
  feedList.addEventListener('click', (event) => {
    const button = event.target.closest('[data-like-id]');

    if (!button) {
      return;
    }

    toggleLike(button.dataset.likeId, button);
  });

  supabase.auth.onAuthStateChange((_event, session) => {
    currentSession = session;
    renderAuth();
    fetchTweets({ silent: true });
  });

  const {
    data: { session },
  } = await supabase.auth.getSession();

  currentSession = session;
  renderAuth();
  updateSubmitState();
  mountRealtime();
  fetchTweets();
  window.setInterval(() => fetchTweets({ silent: true }), 15000);
</script>
