---
import BaseLayout from '../../layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="aPulse | 推文详情" description="查看推文详情与评论">
  <div class="mx-auto min-h-screen max-w-2xl border-x border-white/10 bg-black text-white">
    <header class="sticky top-0 z-20 border-b border-white/10 bg-black/80 backdrop-blur-xl">
      <div class="flex items-center gap-4 px-4 py-3 sm:px-6">
        <a
          href="/"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-white/70 transition hover:border-white/20 hover:bg-white/[0.08] hover:text-white"
          aria-label="返回首页"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5" /><path d="m12 19-7-7 7-7" />
          </svg>
        </a>
        <div>
          <h1 class="text-lg font-bold text-white">推文详情</h1>
          <p id="detail-status" class="text-xs text-white/45">加载中...</p>
        </div>
      </div>
    </header>

    <article id="tweet-detail" class="hidden">
      <div class="border-b border-white/10 px-4 py-5 sm:px-6">
        <div class="flex items-start gap-4">
          <div id="td-avatar" class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/[0.05] text-sm font-black text-white/80"></div>
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
              <span id="td-author" class="text-sm font-semibold text-white"></span>
              <span class="text-sm text-white/25">·</span>
              <span id="td-time" class="text-sm text-white/45"></span>
            </div>
            <p id="td-content" class="mt-3 whitespace-pre-wrap text-[15px] leading-7 text-white/85"></p>
            <div id="td-image-container" class="mt-4 hidden overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/[0.03]">
              <img id="td-image" src="" alt="tweet image" loading="lazy" class="max-h-[30rem] w-full object-cover" />
            </div>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-6 border-b border-white/10 px-4 py-3 sm:px-6">
        <button id="td-like-btn" type="button" class="inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-sm text-white/55 transition hover:bg-rose-500/10 hover:text-rose-300" aria-label="点赞">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
          </svg>
          <span id="td-like-count">0</span>
        </button>
        <button id="td-bookmark-btn" type="button" class="inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-sm text-white/55 transition hover:bg-amber-500/10 hover:text-amber-300" aria-label="书签">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z" />
          </svg>
          <span id="td-bookmark-label">收藏</span>
        </button>
        <button id="td-share-btn" type="button" class="inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-sm text-white/55 transition hover:bg-cyan-500/10 hover:text-cyan-300" aria-label="分享">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" x2="12" y1="2" y2="15"/>
          </svg>
          <span>分享</span>
        </button>
      </div>
    </article>

    <article id="td-not-found" class="hidden px-4 py-16 text-center text-white/50">
      <p class="text-lg">推文不存在或已被删除。</p>
      <a href="/" class="mt-4 inline-block rounded-full border border-white/10 px-5 py-2 text-sm font-semibold text-white/80 transition hover:bg-white/[0.06]">返回首页</a>
    </article>

    <section id="comments-section" class="hidden">
      <div class="border-b border-white/10 px-4 py-4 sm:px-6">
        <h2 class="text-base font-bold text-white">评论 <span id="comment-count" class="text-sm font-normal text-white/45"></span></h2>
      </div>

      <div id="comment-form-area" class="border-b border-white/10 px-4 py-4 sm:px-6">
        <form id="comment-form" class="flex items-start gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/[0.05] text-xs font-black uppercase text-white/60">C</div>
          <div class="min-w-0 flex-1">
            <textarea id="comment-input" rows="2" placeholder="写下你的评论..." class="min-h-[3rem] w-full resize-none border-0 bg-transparent px-0 text-sm leading-6 text-white outline-none placeholder:text-white/30 focus:ring-0"></textarea>
            <div class="mt-2 flex items-center justify-between">
              <p id="comment-status" class="text-xs text-white/45"></p>
              <div class="flex items-center gap-2">
                <span id="comment-char-count" class="text-xs text-white/45">0 / 500</span>
                <button id="comment-submit-btn" type="submit" disabled class="rounded-full bg-cyan-500 px-4 py-1.5 text-xs font-semibold text-slate-950 transition hover:bg-cyan-400 disabled:cursor-not-allowed disabled:bg-white/10 disabled:text-white/35">发送</button>
              </div>
            </div>
          </div>
        </form>
      </div>

      <div id="comment-list" class="divide-y divide-white/10"></div>
    </section>

    <div id="td-loading" class="flex items-center justify-center py-24 text-sm text-white/45">
      <svg class="h-5 w-5 animate-spin text-cyan-400" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="31.4 31.4" stroke-linecap="round" /></svg>
      <span class="ml-3">加载中...</span>
    </div>
  </div>

  <!-- 分享海报弹窗 -->
  <div id="share-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/70 backdrop-blur-sm">
    <div class="w-full max-w-sm rounded-3xl border border-white/10 bg-zinc-900 p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold text-white">分享推文</h3>
        <button id="share-modal-close" type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-full text-white/50 transition hover:bg-white/[0.06] hover:text-white">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-3 mb-4">
        <canvas id="share-canvas" class="hidden"></canvas>
        <img id="share-poster-preview" src="" alt="海报预览" class="w-full rounded-xl" />
      </div>
      <div class="flex gap-2">
        <button id="share-copy-image-btn" type="button" class="flex-1 rounded-full bg-cyan-500 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400">📋 复制海报图片</button>
        <button id="share-copy-link-btn" type="button" class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2.5 text-sm font-semibold text-white/70 transition hover:border-cyan-400/40 hover:text-white">🔗 复制链接</button>
      </div>
      <p id="share-status" class="mt-3 text-center text-xs text-white/40"></p>
    </div>
  </div>

  <style>
    @keyframes like-bounce {
      0% { transform: scale(1); }
      30% { transform: scale(1.35); }
      60% { transform: scale(0.9); }
      100% { transform: scale(1); }
    }
    @keyframes bookmark-pop {
      0% { transform: scale(1); }
      40% { transform: scale(1.3); }
      70% { transform: scale(0.95); }
      100% { transform: scale(1); }
    }
  </style>

  <script>
  import { createBrowserSupabase } from '../../lib/supabase.js';

  const supabase = createBrowserSupabase();
  const tweetId = window.location.pathname.split('/').pop();

  const tweetDetail = document.querySelector('#tweet-detail');
  const tdNotFound = document.querySelector('#td-not-found');
  const tdLoading = document.querySelector('#td-loading');
  const tdStatus = document.querySelector('#detail-status');
  const tdAvatar = document.querySelector('#td-avatar');
  const tdAuthor = document.querySelector('#td-author');
  const tdTime = document.querySelector('#td-time');
  const tdContent = document.querySelector('#td-content');
  const tdImageContainer = document.querySelector('#td-image-container');
  const tdImage = document.querySelector('#td-image');
  const tdLikeBtn = document.querySelector('#td-like-btn');
  const tdLikeCount = document.querySelector('#td-like-count');
  const tdBookmarkBtn = document.querySelector('#td-bookmark-btn');
  const tdBookmarkLabel = document.querySelector('#td-bookmark-label');

  const commentsSection = document.querySelector('#comments-section');
  const commentForm = document.querySelector('#comment-form');
  const commentInput = document.querySelector('#comment-input');
  const commentSubmitBtn = document.querySelector('#comment-submit-btn');
  const commentStatus = document.querySelector('#comment-status');
  const commentCount = document.querySelector('#comment-count');
  const commentCharCount = document.querySelector('#comment-char-count');
  const commentList = document.querySelector('#comment-list');

  const MAX_COMMENT_LENGTH = 500;
  let session = null;
  let tweet = null;
  let comments = [];
  let viewerHasLiked = false;
  let viewerHasBookmarked = false;

  function escapeHtml(value) {
    return String(value).replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#39;');
  }

  function formatAuthor(userId) {
    if (!userId) return 'Unknown';
    if (session?.user?.id === userId) return '你';
    return `@${userId.slice(0, 8)}`;
  }

  function formatRelativeTime(value) {
    const now = Date.now();
    const target = new Date(value).getTime();
    const diffSeconds = Math.round((target - now) / 1000);
    const formatter = new Intl.RelativeTimeFormat('zh-CN', { numeric: 'auto' });
    const ranges = [
      { unit: 'day', seconds: 86400 },
      { unit: 'hour', seconds: 3600 },
      { unit: 'minute', seconds: 60 },
      { unit: 'second', seconds: 1 },
    ];
    for (const r of ranges) {
      if (Math.abs(diffSeconds) >= r.seconds || r.unit === 'second') {
        return formatter.format(Math.round(diffSeconds / r.seconds), r.unit);
      }
    }
    return '刚刚';
  }

  function toFriendlyErrorMessage(error) {
    if (!error?.message) return '发生未知错误。';
    if (error.message === 'Anonymous sign-ins are disabled') return 'Supabase 未启用匿名登录。';
    if (error.message.includes('row-level security policy')) return '操作被 RLS 策略拒绝。';
    return error.message;
  }

  function updateLikeButton() {
    const isFilled = viewerHasLiked;
    tdLikeBtn.querySelector('svg').setAttribute('fill', isFilled ? '#fb7185' : 'none');
    tdLikeBtn.querySelector('svg').setAttribute('stroke', isFilled ? '#fb7185' : 'currentColor');
    tdLikeBtn.classList.toggle('text-rose-300', isFilled);
    tdLikeBtn.classList.toggle('text-white/55', !isFilled);
    tdLikeCount.textContent = tweet?.likes_count ?? 0;
  }

  function updateBookmarkButton() {
    const isFilled = viewerHasBookmarked;
    tdBookmarkBtn.querySelector('svg').setAttribute('fill', isFilled ? '#f59e0b' : 'none');
    tdBookmarkBtn.querySelector('svg').setAttribute('stroke', isFilled ? '#f59e0b' : 'currentColor');
    tdBookmarkBtn.classList.toggle('text-amber-300', isFilled);
    tdBookmarkBtn.classList.toggle('text-white/55', !isFilled);
    tdBookmarkLabel.textContent = isFilled ? '已收藏' : '收藏';
  }

  async function ensureSession() {
    const { data: { session: existing } } = await supabase.auth.getSession();
    if (existing) { session = existing; return existing; }
    const { data, error } = await supabase.auth.signInAnonymously();
    if (error) throw new Error(toFriendlyErrorMessage(error));
    session = data.session ?? null;
    if (!session) throw new Error('匿名会话创建失败。');
    return session;
  }

  async function loadTweet() {
    const { data, error } = await supabase
      .from('tweets')
      .select('id, content, image_url, created_at, user_id, likes_count, city, topic')
      .eq('id', tweetId)
      .single();

    if (error || !data) {
      tdLoading.classList.add('hidden');
      tdNotFound.classList.remove('hidden');
      tdStatus.textContent = '推文未找到';
      return;
    }

    tweet = data;
    tdLoading.classList.add('hidden');
    tweetDetail.classList.remove('hidden');
    commentsSection.classList.remove('hidden');
    tdStatus.textContent = '已加载';

    const badge = escapeHtml(formatAuthor(data.user_id).replace('@', '').slice(0, 2).toUpperCase() || '?');
    tdAvatar.textContent = badge;
    tdAuthor.textContent = formatAuthor(data.user_id);
    tdTime.textContent = formatRelativeTime(data.created_at);
    tdContent.textContent = data.content || '';

    if (data.image_url) {
      tdImageContainer.classList.remove('hidden');
      tdImage.src = data.image_url;
    } else {
      tdImageContainer.classList.add('hidden');
    }

    // 检查用户是否已点赞/已收藏
    if (session) {
      const [{ data: like }, { data: bookmark }] = await Promise.all([
        supabase.from('tweet_likes').select('tweet_id').eq('tweet_id', tweetId).eq('user_id', session.user.id).maybeSingle(),
        supabase.from('bookmarks').select('tweet_id').eq('tweet_id', tweetId).eq('user_id', session.user.id).maybeSingle(),
      ]);
      viewerHasLiked = Boolean(like);
      viewerHasBookmarked = Boolean(bookmark);
    } else {
      viewerHasLiked = false;
      viewerHasBookmarked = false;
    }

    updateLikeButton();
    updateBookmarkButton();
    loadComments();
  }

  async function loadComments() {
    const { data, error } = await supabase
      .from('comments')
      .select('id, content, created_at, user_id')
      .eq('tweet_id', tweetId)
      .order('created_at', { ascending: true });

    if (error) return;
    comments = data ?? [];
    renderComments();
  }

  function renderComments() {
    commentCount.textContent = `(${comments.length})`;

    if (!comments.length) {
      commentList.innerHTML = `<div class="px-4 py-10 text-center text-sm text-white/35">还没有评论，来发表第一条吧。</div>`;
      return;
    }

    commentList.innerHTML = comments.map(c => {
      const isOwn = session?.user?.id === c.user_id;
      const badge = escapeHtml(formatAuthor(c.user_id).replace('@', '').slice(0, 2).toUpperCase() || '?');
      return `
        <div class="group px-4 py-4 transition hover:bg-white/[0.02] sm:px-6" data-comment-id="${c.id}">
          <div class="flex items-start gap-3">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/[0.05] text-[10px] font-black text-white/60">${badge}</div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <span class="text-xs font-semibold text-white">${escapeHtml(formatAuthor(c.user_id))}</span>
                <span class="text-xs text-white/25">·</span>
                <span class="text-xs text-white/40">${escapeHtml(formatRelativeTime(c.created_at))}</span>
                ${isOwn ? `<button type="button" class="delete-comment-btn ml-auto text-xs text-rose-400/60 opacity-0 transition hover:text-rose-300 group-hover:opacity-100" data-comment-id="${c.id}">删除</button>` : ''}
              </div>
              <p class="mt-1 whitespace-pre-wrap text-sm leading-6 text-white/80">${escapeHtml(c.content)}</p>
            </div>
          </div>
        </div>
      `;
    }).join('');

    // 绑定删除事件
    commentList.querySelectorAll('.delete-comment-btn').forEach(btn => {
      btn.addEventListener('click', () => deleteComment(btn.dataset.commentId));
    });
  }

  async function submitComment(event) {
    event.preventDefault();
    const content = commentInput.value.trim();
    if (!content) { commentStatus.textContent = '请输入评论内容。'; return; }
    if (content.length > MAX_COMMENT_LENGTH) { commentStatus.textContent = `评论不能超过 ${MAX_COMMENT_LENGTH} 字。`; return; }
    if (!session) { commentStatus.textContent = '请先登录。'; return; }

    commentSubmitBtn.disabled = true;
    commentStatus.textContent = '发送中...';

    const { error } = await supabase.from('comments').insert({
      tweet_id: tweetId,
      content,
      user_id: session.user.id,
    });

    if (error) {
      commentStatus.textContent = toFriendlyErrorMessage(error);
      commentSubmitBtn.disabled = false;
      return;
    }

    commentInput.value = '';
    updateCommentComposer();
    commentStatus.textContent = '评论已发送。';
    await loadComments();
    commentSubmitBtn.disabled = false;
  }

  async function deleteComment(commentId) {
    if (!session) return;
    const { error } = await supabase.from('comments').delete().eq('id', commentId).eq('user_id', session.user.id);
    if (error) { commentStatus.textContent = toFriendlyErrorMessage(error); return; }
    await loadComments();
  }

  async function toggleLike() {
    if (!session) { commentStatus.textContent = '请先登录再点赞。'; return; }
    // 立即播放动画
    const svg = tdLikeBtn.querySelector('svg');
    if (svg) {
      svg.style.animation = 'none';
      svg.offsetHeight;
      svg.style.animation = 'like-bounce 0.4s ease-out';
    }

    if (viewerHasLiked) {
      await supabase.from('tweet_likes').delete().eq('tweet_id', tweetId).eq('user_id', session.user.id);
      viewerHasLiked = false;
      tweet.likes_count = Math.max(0, (tweet.likes_count || 1) - 1);
    } else {
      await supabase.from('tweet_likes').insert({ tweet_id: tweetId, user_id: session.user.id });
      viewerHasLiked = true;
      tweet.likes_count = (tweet.likes_count || 0) + 1;
    }

    updateLikeButton();
  }

  async function toggleBookmark() {
    if (!session) { commentStatus.textContent = '请先登录再收藏。'; return; }
    const svg = tdBookmarkBtn.querySelector('svg');
    if (svg) {
      svg.style.animation = 'none';
      svg.offsetHeight;
      svg.style.animation = 'bookmark-pop 0.4s ease-out';
    }

    if (viewerHasBookmarked) {
      await supabase.from('bookmarks').delete().eq('tweet_id', tweetId).eq('user_id', session.user.id);
      viewerHasBookmarked = false;
    } else {
      await supabase.from('bookmarks').insert({ tweet_id: tweetId, user_id: session.user.id });
      viewerHasBookmarked = true;
    }

    updateBookmarkButton();
  }

  function updateCommentComposer() {
    const len = commentInput.value.length;
    const trimmed = commentInput.value.trim().length;
    commentCharCount.textContent = `${len} / ${MAX_COMMENT_LENGTH}`;
    commentCharCount.className = len > MAX_COMMENT_LENGTH
      ? 'text-xs text-rose-400'
      : 'text-xs text-white/45';
    commentSubmitBtn.disabled = !trimmed || len > MAX_COMMENT_LENGTH;
  }

  // ===== 分享海报 =====
  const tdShareBtn = document.querySelector('#td-share-btn');
  const shareModal = document.querySelector('#share-modal');
  const shareCanvas = document.querySelector('#share-canvas');
  const sharePosterPreview = document.querySelector('#share-poster-preview');
  const shareStatus = document.querySelector('#share-status');

  async function generatePoster() {
    if (!tweet) return;
    const W = 600;
    const padding = 40;
    const authorName = formatAuthor(tweet.user_id);
    const shortId = (tweet.user_id || '').slice(0, 8);

    shareCanvas.width = W;
    let y = padding;
    let contentLines = [];
    if (tweet.content) {
      const words = tweet.content.split('');
      let line = '';
      for (const ch of words) {
        const testLine = line + ch;
        if (testLine.length > 40) { contentLines.push(line); line = ch; }
        else line = testLine;
      }
      if (line) contentLines.push(line);
    }

    let imageHeight = tweet.image_url ? 280 : 0;
    const contentTextHeight = contentLines.length * 28;
    const H = padding + 50 + contentTextHeight + 20 + imageHeight + (imageHeight ? 16 : 0) + 50 + padding + 30;
    shareCanvas.height = Math.max(H, 280);

    const ctx = shareCanvas.getContext('2d');
    ctx.fillStyle = '#0a0a0a';
    const r = 24;
    ctx.beginPath();
    ctx.moveTo(r, 0);
    ctx.lineTo(W - r, 0);
    ctx.quadraticCurveTo(W, 0, W, r);
    ctx.lineTo(W, shareCanvas.height - r);
    ctx.quadraticCurveTo(W, shareCanvas.height, W - r, shareCanvas.height);
    ctx.lineTo(r, shareCanvas.height);
    ctx.quadraticCurveTo(0, shareCanvas.height, 0, shareCanvas.height - r);
    ctx.lineTo(0, r);
    ctx.quadraticCurveTo(0, 0, r, 0);
    ctx.fill();

    ctx.fillStyle = '#38bdf8';
    ctx.font = 'bold 20px sans-serif';
    ctx.fillText('aPulse', padding, y + 20);
    y += 50;

    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 16px sans-serif';
    ctx.fillText(authorName, padding, y);
    ctx.fillStyle = '#888888';
    ctx.font = '13px sans-serif';
    ctx.fillText(`@${shortId}`, padding + ctx.measureText(authorName).width + 10, y);
    y += 32;

    ctx.strokeStyle = 'rgba(255,255,255,0.1)';
    ctx.beginPath();
    ctx.moveTo(padding, y);
    ctx.lineTo(W - padding, y);
    ctx.stroke();
    y += 16;

    ctx.fillStyle = '#e0e0e0';
    ctx.font = '15px sans-serif';
    for (const line of contentLines) {
      ctx.fillText(line, padding, y + 20);
      y += 28;
    }
    if (!tweet.content) { ctx.fillText('[图片]', padding, y + 20); y += 28; }

    if (tweet.image_url && imageHeight > 0) {
      y += 8;
      try {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        await new Promise((resolve, reject) => {
          img.onload = resolve;
          img.onerror = reject;
          img.src = tweet.image_url;
          setTimeout(() => reject(new Error('timeout')), 5000);
        });
        const imgW = W - padding * 2;
        ctx.save();
        ctx.beginPath();
        ctx.roundRect(padding, y, imgW, imageHeight, 16);
        ctx.clip();
        ctx.drawImage(img, padding, y, imgW, imageHeight);
        ctx.restore();
        y += imageHeight + 16;
      } catch {}
    }

    y += 8;
    ctx.strokeStyle = 'rgba(255,255,255,0.08)';
    ctx.beginPath();
    ctx.moveTo(padding, y);
    ctx.lineTo(W - padding, y);
    ctx.stroke();
    y += 20;

    const metaParts = [];
    if (tweet.city) metaParts.push(`📍 ${tweet.city}`);
    if (tweet.topic) metaParts.push(`🏷 ${tweet.topic}`);
    if (metaParts.length) {
      ctx.fillStyle = '#999';
      ctx.font = '12px sans-serif';
      ctx.fillText(metaParts.join(' · '), padding, y + 16);
    }
    const ts = new Date(tweet.created_at).toLocaleString('zh-CN', { hour12: false });
    ctx.fillStyle = '#666';
    ctx.font = '11px sans-serif';
    ctx.fillText(ts, padding, y + 36);
    ctx.fillStyle = '#38bdf8';
    ctx.font = '11px sans-serif';
    ctx.fillText('来自 aPulse — 说什么都能被听见', padding, shareCanvas.height - padding + 10);
  }

  async function shareAsPoster() {
    shareModal.classList.remove('hidden');
    shareStatus.textContent = '正在生成海报...';
    sharePosterPreview.classList.add('hidden');
    try {
      await generatePoster();
      const dataUrl = shareCanvas.toDataURL('image/png');
      sharePosterPreview.src = dataUrl;
      sharePosterPreview.classList.remove('hidden');
      shareStatus.textContent = '';
    } catch {
      shareStatus.textContent = '海报生成失败';
    }
  }

  async function copyPosterImage() {
    try {
      const blob = await new Promise(resolve => shareCanvas.toBlob(resolve, 'image/png'));
      await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })]);
      shareStatus.textContent = '海报已复制到剪贴板 ✓';
    } catch {
      const a = document.createElement('a');
      a.download = `apulse-${tweetId}.png`;
      a.href = shareCanvas.toDataURL('image/png');
      a.click();
      shareStatus.textContent = '已下载海报图片 ✓';
    }
  }

  async function copyTweetLink() {
    try {
      await navigator.clipboard.writeText(location.href);
      shareStatus.textContent = '链接已复制 ✓';
    } catch {
      shareStatus.textContent = location.href;
    }
  }

  tdShareBtn.addEventListener('click', shareAsPoster);
  document.querySelector('#share-modal-close').addEventListener('click', () => shareModal.classList.add('hidden'));
  shareModal.addEventListener('click', (e) => { if (e.target === shareModal) shareModal.classList.add('hidden'); });
  document.querySelector('#share-copy-image-btn').addEventListener('click', copyPosterImage);
  document.querySelector('#share-copy-link-btn').addEventListener('click', copyTweetLink);

  // 绑定事件
  tdLikeBtn.addEventListener('click', toggleLike);
  tdBookmarkBtn.addEventListener('click', toggleBookmark);
  commentForm.addEventListener('submit', submitComment);
  commentInput.addEventListener('input', updateCommentComposer);

  // 初始化
  try {
    await ensureSession();
  } catch (e) {
    tdStatus.textContent = '会话初始化失败';
  }

  await loadTweet();

  // 实时更新评论
  const commentChannel = supabase
    .channel(`tweet-comments-${tweetId}`)
    .on('postgres_changes', { event: '*', schema: 'public', table: 'comments', filter: `tweet_id=eq.${tweetId}` }, () => {
      loadComments();
    })
    .subscribe();
  </script>
</BaseLayout>
