  function findNearestCity(lat, lng) {
    let bestCity = null;
    let bestDist = Infinity;
    for (const [city, [clat, clng]] of Object.entries(CITY_COORDS)) {
      const dist = Math.hypot(lat - clat, lng - clng);
      if (dist < bestDist) { bestDist = dist; bestCity = city; }
    }
    return bestDist < 1.2 ? bestCity : null;
  }

  async function extractExif(file) {
    try {
      const exifr = (await import('exifr')).default;
      const data = await exifr.parse(file, ['GPSLatitude', 'GPSLongitude', 'DateTimeOriginal', 'Make', 'Model']);
      if (!data) return null;
      const lat = data.latitude;
      const lng = data.longitude;
      const camera = [data.Make, data.Model].filter(Boolean).join(' ').trim() || null;
      const date = data.DateTimeOriginal ? new Date(data.DateTimeOriginal).toLocaleDateString('zh-CN') : null;
      return { lat, lng, camera, date, city: (lat != null && lng != null) ? findNearestCity(lat, lng) : null };
    } catch { return null; }
  }

  let currentView = 'timeline'; // 'timeline' | 'bookmarks' | 'starred' | 'search'

  function escapeHtml(value) {
    return String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function formatAuthor(userId) {
    if (!userId) {
      return 'Unknown';
    }

    if (session?.user?.id === userId) {
      return '你';
    }

    return `@${userId.slice(0, 8)}`;
  }

  function getDisplayName(session) {
    if (!session) return { label: '未登录', sub: '' };
    const provider = session.user?.app_metadata?.provider;
    const shortId = session.user.id.slice(0, 8);
    const email = session.user.email || '';
    const prefix = email.split('@')[0] || shortId;
    if (provider === 'google') {
      return { label: `🌟 Google · ${prefix}`, sub: email || shortId };
    }
    if (provider === 'email') {
      return { label: `🔐 ${prefix}`, sub: email };
    }
    return { label: `👣 游客`, sub: shortId };
  }

  function updateSessionLabel() {
    const info = getDisplayName(session);
    sessionLabel.textContent = session ? info.label : '正在初始化...';
    sessionIdentity.textContent = session ? info.sub : '';
  }

  function formatRelativeTime(value) {
    const now = Date.now();
    const target = new Date(value).getTime();
    const diffSeconds = Math.round((target - now) / 1000);
    const ranges = [
      { unit: 'day', seconds: 86400 },
      { unit: 'hour', seconds: 3600 },
      { unit: 'minute', seconds: 60 },
      { unit: 'second', seconds: 1 },
    ];

    for (const range of ranges) {
      if (Math.abs(diffSeconds) >= range.seconds || range.unit === 'second') {
        return relativeTimeFormatter.format(Math.round(diffSeconds / range.seconds), range.unit);
      }
    }

    return '刚刚';
  }

  function sanitizeFileName(value) {
    return value.replace(/[^a-zA-Z0-9._-]/g, '-');
  }

