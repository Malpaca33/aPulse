---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="aPulse | 发现世界的新跳动。" description="aPulse | 发现世界的新跳动。">
  <section class="min-h-screen bg-black text-white">
    <div class="flex min-h-screen" style="width:100%;max-width:1600px;margin:0 auto">
      <aside class="hidden border-r border-white/10 px-6 py-8 xl:sticky xl:top-0 xl:block xl:h-screen xl:w-[17rem] xl:shrink-0 xl:overflow-y-auto">
        <div class="space-y-8">
          <a
            href="/"
            class="inline-flex items-center gap-3 rounded-full border border-sky-400/20 bg-sky-400/10 px-5 py-3 text-3xl font-black italic tracking-tight text-sky-400 transition hover:scale-[1.02] hover:border-sky-300/40 hover:bg-sky-400/15"
            aria-label="aPulse Home" transition:name="logo"
          >
            <span class="inline-flex h-3 w-3 rounded-full bg-sky-300 shadow-[0_0_20px_rgba(56,189,248,0.9)]"></span>
            <span>aPulse</span>
          </a>

          <nav class="space-y-2">
            <a href="/" class="flex items-center gap-3 rounded-full px-4 py-3 text-base font-semibold transition hover:bg-white/[0.06]" data-view="timeline">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/[0.06] text-xl">⌂</span>
              <span>主页</span>
            </a>
            <a href="/photos" class="flex items-center gap-3 rounded-full px-4 py-3 text-base font-semibold text-white/70 transition hover:bg-white/[0.06] hover:text-white">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/[0.06] text-xl">📷</span>
              <span>照片墙</span>
            </a>
            <a href="/" class="flex items-center gap-3 rounded-full px-4 py-3 text-base font-semibold text-white/70 transition hover:bg-white/[0.06] hover:text-white" data-view="bookmarks">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/[0.06] text-xl">🔖</span>
              <span>书签</span>
            </a>
            <a href="/" class="flex items-center gap-3 rounded-full px-4 py-3 text-base font-semibold text-white/70 transition hover:bg-white/[0.06] hover:text-white" data-view="starred">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/[0.06] text-xl">⭐</span>
              <span>精华</span>
            </a>
          </nav>

          <div id="notif-panel" class="rounded-3xl border border-white/10 bg-zinc-900 p-4 shadow-2xl">
            <div class="mb-3">
              <h3 class="text-sm font-bold text-white">通知</h3>
            </div>
            <div id="notif-list" class="max-h-80 space-y-2 overflow-y-auto">
              <p class="py-4 text-center text-xs text-white/40">暂无通知。</p>
            </div>
          </div>

          <div id="status-card" class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 shadow-[0_0_0_1px_rgba(255,255,255,0.02)] backdrop-blur">
            <p class="text-[11px] font-semibold uppercase tracking-[0.35em] text-cyan-400">身份</p>
            <p id="session-label" class="mt-3 text-base font-bold text-white">正在初始化...</p>
            <p id="session-identity" class="mt-0.5 text-xs text-white/40"></p>
            <div id="sidebar-login-buttons" class="mt-3 flex flex-wrap gap-2">
              <button id="google-login-button" type="button" class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-xs font-semibold text-white/70 transition hover:border-sky-400/40 hover:bg-sky-400/10 hover:text-white">Google</button>
              <button id="email-login-button" type="button" class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-xs font-semibold text-white/70 transition hover:border-cyan-400/40 hover:bg-cyan-400/10 hover:text-white">✉️ 密码</button>
              <button id="anon-login-button" type="button" class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-xs font-semibold text-white/70 transition hover:border-cyan-400/40 hover:bg-cyan-400/10 hover:text-white">匿名</button>
              <button id="edit-profile-button" type="button" class="rounded-full border border-amber-400/20 bg-amber-400/10 px-3 py-1.5 text-xs font-semibold text-amber-300/80 transition hover:border-amber-300/40 hover:bg-amber-400/15 hover:text-amber-200">✏️ 资料</button>
              <button id="sign-out-button" type="button" class="hidden rounded-full border border-rose-400/20 bg-rose-500/10 px-3 py-1.5 text-xs font-semibold text-rose-300/80 transition hover:border-rose-300/40 hover:bg-rose-500/15 hover:text-rose-200">退出</button>
            </div>
          </div>
        </div>
      </aside>

      <main class="min-w-0 border-x border-white/10">
        <header class="sticky top-0 z-20 border-b border-white/10 bg-black/80 backdrop-blur-xl">
          <div class="px-4 py-4 sm:px-6">
            <p class="text-[11px] font-semibold uppercase tracking-[0.35em] text-cyan-400">For You</p>
            <div class="mt-2 flex items-end justify-between gap-4">
              <div>
                <h1 class="text-2xl font-black tracking-tight text-white" transition:name="page-title">Home</h1>
                <p class="mt-1 text-sm text-white/55">Astro + Supabase 的实时推文流</p>
              </div>
              <button
                id="refresh-button"
                type="button"
                class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-semibold text-white/80 transition hover:border-cyan-400/40 hover:bg-cyan-400/10 hover:text-white"
              >
                刷新
              </button>
            </div>
          </div>
        </header>

        <section id="composer" class="relative overflow-hidden border-b border-white/10">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(56,189,248,0.14),transparent_45%),linear-gradient(180deg,rgba(255,255,255,0.03),transparent)]"></div>
          <div class="relative px-4 py-5 sm:px-6">
            <div class="flex items-start gap-4">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full border border-cyan-400/20 bg-cyan-400/10 text-sm font-black uppercase text-cyan-300">
                ME
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <p class="text-lg font-semibold text-white">有什么新鲜事？</p>
                    <p id="composer-hint" class="mt-1 text-sm text-white/55">正在连接 Supabase...</p>
                  </div>
                  <div id="char-count" class="inline-flex rounded-full border border-white/10 bg-white/[0.05] px-3 py-1 text-xs font-semibold text-white/60">
                    0 / 280
                  </div>
                </div>

                <form id="tweet-form" class="mt-4">
                  <label class="block">
                    <span class="sr-only">推文内容</span>
                    <textarea
                      id="tweet-input"
                      rows="5"
                      placeholder="分享你的构建进度、想法或灵感..."
                      class="min-h-[9rem] w-full resize-none border-0 bg-transparent px-0 text-lg leading-8 text-white outline-none placeholder:text-white/30 focus:ring-0"
                    ></textarea>
                  </label>

                  <input id="image-input" type="file" accept="image/*" class="hidden" />
                  <div id="image-preview-panel" class="mt-4 hidden overflow-hidden rounded-[1.75rem] border border-white/10 bg-white/[0.04]">
                    <div class="flex items-center justify-between border-b border-white/10 px-4 py-3">
                      <p class="text-sm font-semibold text-white/80">图片预览</p>
                      <button
                        id="remove-image-button"
                        type="button"
                        class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-white/70 transition hover:border-rose-300/40 hover:bg-rose-500/10 hover:text-rose-200"
                        aria-label="取消已选图片"
                      >
                        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M18 6 6 18" />
                          <path d="m6 6 12 12" />
                        </svg>
                      </button>
                    </div>
                    <div class="p-4">
                      <img
                        id="image-preview"
                        src=""
                        alt="已选择的图片预览"
                        class="max-h-[22rem] w-full rounded-[1.25rem] object-cover"
                      />
                    </div>
                  </div>

                  <!-- 照片标签：地点选择 + EXIF + 主题 -->
                  <div id="photo-meta" class="mt-3 hidden flex-col gap-3">
                    <div id="exif-info" class="hidden rounded-2xl border border-cyan-400/15 bg-cyan-400/[0.04] px-4 py-3">
                      <div class="flex items-center gap-2 text-xs">
                        <span id="exif-status-icon" class="text-base">📡</span>
                        <span id="exif-status-text" class="text-white/70">读取中...</span>
                      </div>
                      <div id="exif-details" class="mt-2 hidden space-y-1">
                        <p id="exif-camera" class="text-xs text-white/50"></p>
                        <p id="exif-date" class="text-xs text-white/50"></p>
                      </div>
                    </div>
                    <div>
                      <button id="city-picker-btn" type="button" class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-xs text-white/60 transition hover:border-cyan-400/30 hover:text-cyan-300">
                        📍 <span id="city-display">选择拍摄地</span>
                      </button>
                      <div id="city-picker-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/70 backdrop-blur-sm">
                        <div class="max-h-[80vh] w-full max-w-lg overflow-y-auto rounded-3xl border border-white/10 bg-zinc-900 p-5 shadow-2xl">
                          <div class="mb-4 flex items-center justify-between">
                            <h3 class="text-sm font-bold text-white">选择拍摄地</h3>
                            <button id="city-picker-close" type="button" class="inline-flex h-7 w-7 items-center justify-center rounded-full text-white/50 transition hover:bg-white/[0.06] hover:text-white">
                              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                            </button>
                          </div>
                          <div id="province-grid" class="grid grid-cols-4 gap-2"></div>
                          <div id="city-grid" class="mt-3 hidden">
                            <p class="mb-2 text-[11px] font-semibold uppercase tracking-wider text-white/30">选择城市</p>
                            <div class="flex flex-wrap gap-2" id="city-list"></div>
                          </div>
                          <p id="selected-city-display" class="mt-3 text-center text-xs text-cyan-300 hidden"></p>
                        </div>
                      </div>
                    </div>
                    <div class="flex flex-wrap gap-1.5" id="topic-buttons">
                      <span class="text-[10px] font-semibold uppercase tracking-wider text-white/30 mr-1 self-center">风格</span>
                      <button type="button" class="topic-btn rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs text-white/60 transition hover:border-cyan-400/30 hover:text-white" data-topic="街拍">街拍</button>
                      <button type="button" class="topic-btn rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs text-white/60 transition hover:border-cyan-400/30 hover:text-white" data-topic="风光">风光</button>
                      <button type="button" class="topic-btn rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs text-white/60 transition hover:border-cyan-400/30 hover:text-white" data-topic="人像">人像</button>
                      <button type="button" class="topic-btn rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs text-white/60 transition hover:border-cyan-400/30 hover:text-white" data-topic="meme">meme</button>
                    </div>
                  </div>

                  <div class="mt-4 flex flex-col gap-3 border-t border-white/10 pt-4 sm:flex-row sm:items-center sm:justify-between">
                    <div class="space-y-3">
                      <div class="flex flex-wrap items-center gap-2">
                        <button
                          id="media-picker-button"
                          type="button"
                          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-sky-400/20 bg-sky-400/10 text-sky-300 transition hover:border-sky-300/40 hover:bg-sky-400/15 hover:text-sky-200"
                          aria-label="选择图片"
                        >
                          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M4 7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9A2.5 2.5 0 0 1 17.5 19h-11A2.5 2.5 0 0 1 4 16.5v-9Z" />
                            <path d="M8.5 13.5 11 11l2.4 2.4 1.9-1.9L20 16.2" />
                            <circle cx="9" cy="9" r="1.2" fill="currentColor" stroke="none" />
                          </svg>
                        </button>
                        <p id="composer-status" class="text-sm text-white/55">自动匿名登录后即可直接发帖。</p>
                      </div>
                    </div>
                    <div class="flex items-center gap-3 self-end sm:self-auto">
                      <div class="flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5">
                        <svg viewBox="0 0 36 36" class="h-10 w-10 -rotate-90">
                          <circle cx="18" cy="18" r="15.5" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="3"></circle>
                          <circle
                            id="char-ring-progress"
                            cx="18"
                            cy="18"
                            r="15.5"
                            fill="none"
                            stroke="#38bdf8"
                            stroke-width="3"
                            stroke-linecap="round"
                            stroke-dasharray="97.39"
                            stroke-dashoffset="97.39"
                          ></circle>
                        </svg>
                        <span id="char-ring-label" class="min-w-[2rem] text-right text-sm font-semibold text-white/70">0</span>
                      </div>
                      <button
                        id="submit-button"
                        type="submit"
                        class="inline-flex items-center justify-center rounded-full bg-cyan-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400 disabled:cursor-not-allowed disabled:bg-white/10 disabled:text-white/35"
                      >
                        发帖
                      </button>
                    </div>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </section>

        <section id="timeline">
          <div class="border-b border-white/10 px-4 py-3 text-sm text-white/55 sm:px-6">
            <p id="feed-status">正在加载最新推文...</p>
          </div>
          <div id="feed-list" class="divide-y divide-white/10"></div>
        </section>
      </main>

      <aside id="right-sidebar" class="hidden px-6 py-8 xl:block xl:w-[22rem] xl:shrink-0">
        <div class="sticky top-0 space-y-5">
          <section class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 backdrop-blur">
            <div class="relative">
              <input id="search-input" type="text" placeholder="搜索推文..." class="w-full rounded-full border border-white/10 bg-white/[0.05] px-4 py-2.5 pl-10 text-sm text-white outline-none placeholder:text-white/30 focus:border-cyan-400/40 focus:ring-1 focus:ring-cyan-400/20" />
              <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-white/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
          </section>
          <section class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 backdrop-blur">
            <p class="text-[11px] font-semibold uppercase tracking-[0.35em] text-cyan-400">精选</p>
            <h2 class="mt-3 text-xl font-bold text-white">精华帖子</h2>
            <div id="featured-list" class="mt-4 space-y-2 text-sm text-white/65">
              <p class="text-white/40">加载中...</p>
            </div>
          </section>

          <section class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 backdrop-blur">
            <p class="text-[11px] font-semibold uppercase tracking-[0.35em] text-cyan-400">aPulse</p>
            <h2 class="mt-3 text-xl font-bold text-white">脉搏数据</h2>
            <div id="stats-list" class="mt-4 space-y-3">
              <div class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/[0.03] px-4 py-3">
                <span class="text-sm text-white/65">总访问次数</span>
                <span id="stat-page-views" class="text-sm font-semibold text-cyan-300">--</span>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/[0.03] px-4 py-3">
                <span class="text-sm text-white/65">社区活跃达人</span>
                <div id="stat-top-contributors" class="mt-2 space-y-1">
                  <p class="text-xs text-white/40">加载中...</p>
                </div>
              </div>
            </div>
          </section>
        </div>
      </aside>
    </div>
  </section>
  <!-- 个人资料编辑弹窗 -->
  <div id="profile-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="w-full max-w-sm rounded-3xl border border-white/10 bg-zinc-900 p-6 shadow-2xl">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-bold text-white">编辑资料</h3>
        <button id="profile-modal-close" type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-full text-white/50 transition hover:bg-white/[0.06] hover:text-white">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <div class="mt-5 space-y-4">
        <div>
          <label class="text-xs font-semibold text-white/50 uppercase tracking-wider">昵称</label>
          <input id="profile-nickname-input" type="text" maxlength="30" class="mt-1.5 w-full rounded-xl border border-white/10 bg-white/[0.05] px-4 py-2.5 text-sm text-white outline-none placeholder:text-white/30 focus:border-cyan-400/40" placeholder="设置昵称" />
        </div>
        <div>
          <label class="text-xs font-semibold text-white/50 uppercase tracking-wider">简介</label>
          <textarea id="profile-bio-input" rows="3" maxlength="160" class="mt-1.5 w-full resize-none rounded-xl border border-white/10 bg-white/[0.05] px-4 py-2.5 text-sm text-white outline-none placeholder:text-white/30 focus:border-cyan-400/40" placeholder="写一句简介..."></textarea>
        </div>
        <button id="profile-save-btn" type="button" class="w-full rounded-full bg-cyan-500 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400">保存</button>
        <p id="profile-status" class="text-center text-xs text-white/40"></p>
      </div>
    </div>
  </div>

  <!-- 登录/注册弹窗 -->
  <div id="auth-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="w-full max-w-sm rounded-3xl border border-white/10 bg-zinc-900 p-6 shadow-2xl">
      <div class="flex items-center justify-between">
        <h3 id="auth-modal-title" class="text-lg font-bold text-white">登录</h3>
        <button id="auth-modal-close" type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-full text-white/50 transition hover:bg-white/[0.06] hover:text-white">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <div class="mt-5 space-y-4">
        <div>
          <label class="text-xs font-semibold text-white/50 uppercase tracking-wider">邮箱</label>
          <input id="auth-email-input" type="email" autocomplete="email" class="mt-1.5 w-full rounded-xl border border-white/10 bg-white/[0.05] px-4 py-2.5 text-sm text-white outline-none placeholder:text-white/30 focus:border-cyan-400/40" placeholder="your@email.com" />
        </div>
        <div>
          <label class="text-xs font-semibold text-white/50 uppercase tracking-wider">密码</label>
          <input id="auth-password-input" type="password" autocomplete="current-password" class="mt-1.5 w-full rounded-xl border border-white/10 bg-white/[0.05] px-4 py-2.5 text-sm text-white outline-none placeholder:text-white/30 focus:border-cyan-400/40" placeholder="至少 6 位" />
        </div>
        <button id="auth-submit-btn" type="button" class="w-full rounded-full bg-cyan-500 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-cyan-400">登录</button>
        <p id="auth-status" class="text-center text-xs text-white/40"></p>
        <p class="text-center text-xs text-white/30">
          <button id="auth-toggle-btn" type="button" class="text-cyan-400 hover:text-cyan-300 transition">没有账号？点击注册</button>
        </p>
      </div>
    </div>
  </div>

  <script>
  import { createBrowserSupabase } from '../lib/supabase.js';

  const supabase = createBrowserSupabase();
  const tweetForm = document.querySelector('#tweet-form');
  const tweetInput = document.querySelector('#tweet-input');
  const submitButton = document.querySelector('#submit-button');
  const refreshButton = document.querySelector('#refresh-button');
  const imageInput = document.querySelector('#image-input');
  const imagePreviewPanel = document.querySelector('#image-preview-panel');
  const imagePreview = document.querySelector('#image-preview');
  const removeImageButton = document.querySelector('#remove-image-button');
  const mediaPickerButton = document.querySelector('#media-picker-button');
  const googleLoginButton = document.querySelector('#google-login-button');
  const anonLoginButton = document.querySelector('#anon-login-button');
  const feedList = document.querySelector('#feed-list');
  const feedStatus = document.querySelector('#feed-status');
  const composerHint = document.querySelector('#composer-hint');
  const composerStatus = document.querySelector('#composer-status');
  const sessionLabel = document.querySelector('#session-label');
  const sessionIdentity = document.querySelector('#session-identity');
  const featuredList = document.querySelector('#featured-list');
  const statsPageViews = document.querySelector('#stat-page-views');
  const statsTopContributors = document.querySelector('#stat-top-contributors');
  const notifPanel = document.querySelector('#notif-panel');
  const notifList = document.querySelector('#notif-list');
  const notifBadge = document.querySelector('#notif-badge');
  const notifNav = document.querySelector('#nav-notifications');
  const charCount = document.querySelector('#char-count');
  const charRingProgress = document.querySelector('#char-ring-progress');
  const charRingLabel = document.querySelector('#char-ring-label');
