  refreshButton.addEventListener('click', () => fetchTweets());
  mediaPickerButton.addEventListener('click', () => imageInput.click());
  imageInput.addEventListener('change', async () => {
    const nextImage = imageInput.files?.[0];

    if (!nextImage) {
      clearImageSelection();
      return;
    }

    if (!nextImage.type.startsWith('image/')) {
      composerStatus.textContent = '只能选择图片文件。';
      clearImageSelection({ preserveStatus: true });
      return;
    }

    clearImageSelection({ preserveStatus: true });
    selectedImageFile = nextImage;
    selectedImagePreviewUrl = URL.createObjectURL(nextImage);
    imagePreview.src = selectedImagePreviewUrl;
    imagePreviewPanel.classList.remove('hidden');
    document.querySelector('#photo-meta').classList.remove('hidden');

    // 读取 EXIF
    const exifInfo = document.querySelector('#exif-info');
    exifInfo.classList.remove('hidden');
    const exifStatusIcon = document.querySelector('#exif-status-icon');
    const exifStatusText = document.querySelector('#exif-status-text');
    exifStatusIcon.textContent = '📡';
    exifStatusText.textContent = '正在读取照片信息...';

    const exif = await extractExif(nextImage);
    const exifDetails = document.querySelector('#exif-details');
    const exifCamera = document.querySelector('#exif-camera');
    const exifDate = document.querySelector('#exif-date');

    if (exif) {
      exifStatusIcon.textContent = '✅';
      const parts = [];
      if (exif.camera) parts.push(`📷 ${exif.camera}`);
      if (exif.date) parts.push(`📅 ${exif.date}`);
      exifStatusText.textContent = parts.length ? parts.join(' · ') : '已读取照片信息';
      exifStatusText.classList.remove('text-amber-300');
      exifStatusText.classList.add('text-cyan-300');

      // 显示详细信息
      if (exif.camera) { exifCamera.textContent = `相机: ${exif.camera}`; exifCamera.classList.remove('hidden'); }
      else exifCamera.classList.add('hidden');
      if (exif.date) { exifDate.textContent = `拍摄日期: ${exif.date}`; exifDate.classList.remove('hidden'); }
      else exifDate.classList.add('hidden');
      if (exif.camera || exif.date) exifDetails.classList.remove('hidden');

      // GPS → 城市自动填充
      if (exif.city) {
        selectedCity = exif.city;
        const cdEl = document.querySelector('#city-display');
        cdEl.textContent = exif.city;
        cdEl.classList.remove('text-white/60');
        cdEl.classList.add('text-cyan-300');
      } else if (exif.lat != null && exif.lng != null) {
        exifStatusIcon.textContent = '📍';
        exifStatusText.textContent = 'GPS 已识别但无匹配城市，请手动选择';
        exifStatusText.classList.remove('text-cyan-300');
        exifStatusText.classList.add('text-amber-300');
      } else {
        exifStatusText.textContent = '无 GPS 信息，请手动选择城市';
        exifStatusText.classList.remove('text-cyan-300');
        exifStatusText.classList.add('text-amber-300');
      }
    } else {
      exifStatusIcon.textContent = '📷';
      exifStatusText.textContent = '未读取到 EXIF 信息，请手动补充';
      exifStatusText.classList.remove('text-cyan-300');
      exifStatusText.classList.add('text-amber-300');
      exifDetails.classList.add('hidden');
    }

    updateComposerState();
  });
  removeImageButton.addEventListener('click', () => clearImageSelection());
  // 主题按钮选择
  document.querySelectorAll('.topic-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.topic-btn').forEach(b => {
        b.classList.remove('bg-cyan-400/20', 'text-cyan-200', 'border-cyan-400/30');
      });
      btn.classList.add('bg-cyan-400/20', 'text-cyan-200', 'border-cyan-400/30');
      selectedTopic = btn.dataset.topic;
    });
  });
  // 城市选择器
  function renderProvinceGrid() {
    const grid = document.querySelector('#province-grid');
    grid.innerHTML = PROVINCE_NAMES.map(p => `
      <button type="button" class="province-btn rounded-xl border border-white/10 bg-white/[0.03] px-2 py-2.5 text-xs font-semibold text-white/70 transition hover:border-cyan-400/30 hover:bg-cyan-400/10 hover:text-cyan-200" data-province="${p}">
        ${p}
      </button>
    `).join('');
  }
  renderProvinceGrid();

  document.querySelector('#province-grid').addEventListener('click', (e) => {
    const btn = e.target.closest('.province-btn');
    if (!btn) return;
    const province = btn.dataset.province;
    const cities = PROVINCES[province];
    document.querySelectorAll('.province-btn').forEach(b => {
      b.classList.remove('border-cyan-400/40', 'bg-cyan-400/15', 'text-cyan-200');
    });
    btn.classList.add('border-cyan-400/40', 'bg-cyan-400/15', 'text-cyan-200');

    const cityList = document.querySelector('#city-list');
    cityList.innerHTML = cities.map(c => `
      <button type="button" class="city-option rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-xs text-white/70 transition hover:border-amber-400/30 hover:bg-amber-400/10 hover:text-amber-200" data-city="${c}">
        ${c}
      </button>
    `).join('');
    document.querySelector('#city-grid').classList.remove('hidden');
    document.querySelector('#selected-city-display').classList.add('hidden');
  });

  document.querySelector('#city-list').addEventListener('click', (e) => {
    const btn = e.target.closest('.city-option');
    if (!btn) return;
    selectedCity = btn.dataset.city;
    document.querySelector('#city-display').textContent = selectedCity;
    document.querySelector('#city-display').classList.remove('text-white/60');
    document.querySelector('#city-display').classList.add('text-cyan-300');
    document.querySelector('#selected-city-display').textContent = `📍 ${selectedCity}`;
    document.querySelector('#selected-city-display').classList.remove('hidden');
    setTimeout(() => document.querySelector('#city-picker-modal').classList.add('hidden'), 600);
  });

  document.querySelector('#city-picker-btn').addEventListener('click', () => {
    document.querySelector('#city-picker-modal').classList.remove('hidden');
  });
  document.querySelector('#city-picker-close').addEventListener('click', () => {
    document.querySelector('#city-picker-modal').classList.add('hidden');
  });
  document.querySelector('#city-picker-modal').addEventListener('click', (e) => {
    if (e.target === document.querySelector('#city-picker-modal')) {
      document.querySelector('#city-picker-modal').classList.add('hidden');
    }
  });
  googleLoginButton.addEventListener('click', signInWithGoogle);
  anonLoginButton.addEventListener('click', signInAnonymously);

  // 邮箱登录/注册弹窗
  const emailLoginButton = document.querySelector('#email-login-button');
  const signOutButton = document.querySelector('#sign-out-button');
  const authModal = document.querySelector('#auth-modal');
  const authModalClose = document.querySelector('#auth-modal-close');
  const authToggleBtn = document.querySelector('#auth-toggle-btn');
  const authSubmitBtn = document.querySelector('#auth-submit-btn');
  const authModalTitle = document.querySelector('#auth-modal-title');

  emailLoginButton.addEventListener('click', () => {
    authMode = 'login';
    authModalTitle.textContent = '登录';
    authSubmitBtn.textContent = '登录';
    authToggleBtn.textContent = '没有账号？点击注册';
    document.querySelector('#auth-status').textContent = '';
    authModal.classList.remove('hidden');
  });

  signOutButton.addEventListener('click', signOut);
  authModalClose.addEventListener('click', () => authModal.classList.add('hidden'));
  authModal.addEventListener('click', (e) => { if (e.target === authModal) authModal.classList.add('hidden'); });

  authToggleBtn.addEventListener('click', () => {
    authMode = authMode === 'login' ? 'register' : 'login';
    authModalTitle.textContent = authMode === 'login' ? '登录' : '注册';
    authSubmitBtn.textContent = authMode === 'login' ? '登录' : '注册';
    authToggleBtn.textContent = authMode === 'login' ? '没有账号？点击注册' : '已有账号？点击登录';
    document.querySelector('#auth-status').textContent = '';
  });

  authSubmitBtn.addEventListener('click', () => {
    if (authMode === 'login') signInWithEmail();
    else signUpWithEmail();
  });

  document.querySelector('#auth-password-input').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') authSubmitBtn.click();
  });

  function isPersistentSession(s) {
    if (!s) return false;
    const p = s.user?.app_metadata?.provider;
    return p === 'google' || p === 'email';
  }

  supabase.auth.onAuthStateChange((_event, nextSession) => {
    session = nextSession;
    authErrorMessage = '';
    updateSessionLabel();
    updateComposerState();
    const soBtn = document.querySelector('#sign-out-button');
    if (soBtn) soBtn.classList.toggle('hidden', !isPersistentSession(nextSession));
  });

  // 事件委托：点赞 / 精华星 / 书签 / 删除
  feedList.addEventListener('click', (e) => {
    const likeBtn = e.target.closest('[data-like-id]');
    const starBtn = e.target.closest('[data-star-id]');
    const bookmarkBtn = e.target.closest('[data-bookmark-id]');
    const deleteBtn = e.target.closest('[data-delete-id]');
    const commentDeleteBtn = e.target.closest('[data-comment-delete-id]');
    if (likeBtn) { e.preventDefault(); toggleLike(likeBtn.dataset.likeId); }
    if (starBtn) { e.preventDefault(); toggleFeaturedStar(starBtn.dataset.starId); }
    if (bookmarkBtn) { e.preventDefault(); toggleBookmark(bookmarkBtn.dataset.bookmarkId); }
    if (deleteBtn) { e.preventDefault(); deleteTweet(deleteBtn.dataset.deleteId); }
    if (commentDeleteBtn) { e.preventDefault(); deleteComment(commentDeleteBtn.dataset.commentDeleteId); }
  });

  // 搜索事件
  const searchInput = document.querySelector('#search-input');
  if (searchInput) searchInput.addEventListener('input', handleSearchInput);

  // 书签 / 精华 导航
  document.querySelectorAll('nav a[data-view]').forEach((a) => {
    a.addEventListener('click', (e) => { e.preventDefault(); setView(a.dataset.view); });
  });


  // 资料弹窗
  const editProfileBtn = document.querySelector('#edit-profile-button');
  const profileModalClose = document.querySelector('#profile-modal-close');
  const profileSaveBtn = document.querySelector('#profile-save-btn');
  editProfileBtn.addEventListener('click', () => { loadProfile(); profileModal.classList.remove('hidden'); });
  profileModalClose.addEventListener('click', () => profileModal.classList.add('hidden'));
  profileModal.addEventListener('click', (e) => { if (e.target === profileModal) profileModal.classList.add('hidden'); });
  profileSaveBtn.addEventListener('click', saveProfile);

  updateComposerState();

  try {
    await ensureSession();
  } catch (error) {
    authErrorMessage = toFriendlyErrorMessage(error);
    sessionLabel.textContent = '未建立会话';
    updateComposerState();
  }

  mountRealtime();
  mountNotifRealtime();
  await fetchTweets();
  loadFeaturedTweets();
  loadStats();
  updateNotifBadge();
  loadNotifications();
</script>
</BaseLayout>
