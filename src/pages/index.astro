                      <span class="text-xs text-white/25">·</span>
                      <span class="text-xs text-white/40">${escapeHtml(formatRelativeTime(c.created_at))}</span>
                      ${isCommentOwn ? `<button type="button" data-comment-delete-id="${c.id}" class="ml-auto text-xs text-rose-400/60 opacity-0 transition hover:text-rose-300 group-hover/comment:opacity-100">删除</button>` : ''}
                    </div>
                    <p class="mt-0.5 whitespace-pre-wrap text-sm leading-6 text-white/60">${escapeHtml(c.content)}</p>
                  </div>
                `;
              }).join('')}
            </div>
            ` : `<div class="mt-2 pl-16"><a href="/tweet/${tweet.id}" class="text-xs text-white/30 hover:text-white/50 transition">💬 回复</a></div>`}
          </article>
        `;
      })
      .join('');
  }

  async function ensureSession() {
    const {
      data: { session: existingSession },
    } = await supabase.auth.getSession();

    if (existingSession) {
      session = existingSession;
      updateSessionLabel();
      updateComposerState();
      return existingSession;
    }

    const { data, error } = await supabase.auth.signInAnonymously();

    if (error) {
      throw new Error(toFriendlyErrorMessage(error));
    }

    session = data.session ?? null;

    if (!session) {
      throw new Error('匿名会话创建失败。');
    }

    authErrorMessage = '';
    updateSessionLabel();
    updateComposerState();
    return session;
  }

  async function fetchTweets({ silent = false } = {}) {
    const seq = ++fetchSeq;

    if (!silent) feedStatus.textContent = currentView === 'bookmarks'
      ? '正在加载收藏...'
      : currentView === 'starred'
        ? '正在加载精华...'
        : currentView === 'search'
          ? '搜索中...'
          : '正在同步最新推文...';

    try {
      let data;
      if (currentView === 'bookmarks' && session) {
        const { data: ids, error: bErr } = await supabase
          .from('bookmarks')
          .select('tweet_id')
          .eq('user_id', session.user.id)
          .order('created_at', { ascending: false })
          .limit(50);
        if (bErr) throw new Error(toFriendlyErrorMessage(bErr));
        const tweetIds = (ids || []).map(r => r.tweet_id);
        if (tweetIds.length) {
          const { data: tweets } = await supabase.from('tweets').select('*').in('id', tweetIds).order('created_at', { ascending: false });
          data = tweets ?? [];
        } else { data = []; }
      } else if (currentView === 'starred' && session) {
        const { data: ids, error: sErr } = await supabase
          .from('featured_stars')
          .select('tweet_id')
          .eq('user_id', session.user.id)
          .order('created_at', { ascending: false })
          .limit(50);
        if (sErr) throw new Error(toFriendlyErrorMessage(sErr));
        const tweetIds = (ids || []).map(r => r.tweet_id);
        if (tweetIds.length) {
          const { data: tweets } = await supabase.from('tweets').select('*').in('id', tweetIds).order('created_at', { ascending: false });
          data = tweets ?? [];
        } else { data = []; }
      } else if (currentView === 'search' && searchQuery) {
        const { data: rpcData, error: sErr } = await supabase.rpc('search_timeline', { query_text: searchQuery, max_results: 20 });
        if (sErr) throw new Error(toFriendlyErrorMessage(sErr));
        data = rpcData ?? [];
      } else {
        const { data: rpcData, error: tErr } = await supabase.rpc('get_timeline', { max_results: 50 });
        if (tErr) throw new Error(toFriendlyErrorMessage(tErr));
        data = rpcData ?? [];
      }

      // 如果已经被更新的请求覆盖，跳过渲染
      if (seq !== fetchSeq) return;

      let likedIds = [], bookmarkedIds = [], starredIds = [];
      if (session) {
        const [likesRes, bookmarksRes, starsRes] = await Promise.all([
          supabase.from('tweet_likes').select('tweet_id').eq('user_id', session.user.id),
          supabase.from('bookmarks').select('tweet_id').eq('user_id', session.user.id),
          supabase.from('featured_stars').select('tweet_id').eq('user_id', session.user.id),
        ]);
        likedIds = (likesRes.data || []).map((l) => l.tweet_id);
        bookmarkedIds = (bookmarksRes.data || []).map((b) => b.tweet_id);
        starredIds = (starsRes.data || []).map((s) => s.tweet_id);
      }

      renderTweets(data, likedIds, bookmarkedIds, starredIds);
      feedStatus.textContent = `已更新 ${formatRelativeTime(new Date().toISOString())}`;
    } catch (error) {
      feedStatus.textContent = error.message;
    }
  }

  async function toggleLike(tweetId) {
    if (!session) return;
    // DELETE 并检查是否删除了行 — 比 SELECT→DELETE/INSERT 省一次往返
    const { data: deleted } = await supabase
      .from('tweet_likes')
      .delete()
      .eq('tweet_id', tweetId)
      .eq('user_id', session.user.id)
      .select();

    const liked = !deleted || deleted.length === 0;
    if (liked) {
      await supabase.from('tweet_likes').insert({ tweet_id: tweetId, user_id: session.user.id });
    }

    const btn = document.querySelector(`[data-like-id="${tweetId}"]`);
    if (btn) {
      btn.classList.toggle('text-rose-300', liked);
      btn.classList.toggle('text-white/45', !liked);
      const svg = btn.querySelector('svg');
      if (svg) {
        svg.setAttribute('fill', liked ? '#fb7185' : 'none');
        svg.setAttribute('stroke', liked ? '#fb7185' : 'currentColor');
      }
      const countEl = btn.querySelector('span');
      if (countEl) {
        countEl.textContent = liked
          ? (parseInt(countEl.textContent) || 0) + 1
          : Math.max(0, (parseInt(countEl.textContent) || 1) - 1);
      }
    }
  }

