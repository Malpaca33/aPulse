---
import { getCollection, getEntryBySlug } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => p.data.published)
    .map((post) => ({
      params: { slug: post.slug },
      props: { post },
    }));
}

const { slug } = Astro.params;
const post = await getEntryBySlug('blog', slug!);

if (!post) {
  return Astro.redirect('/blog');
}

const { Content } = await post.render();
---

<BaseLayout title={`${post.data.title} — aPulse`} description={post.data.description}>
  <article class="mx-auto max-w-2xl px-4 py-12">
    <header class="mb-8">
      <a href="/blog" class="text-xs text-secondary hover:text-cyan-400 transition-colors">
        &larr; 返回文章列表
      </a>
      <h1 class="text-2xl font-bold mt-4">{post.data.title}</h1>
      <time class="text-xs text-secondary block mt-2">
        {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {post.data.tags.length > 0 && (
        <div class="flex gap-2 mt-2">
          {post.data.tags.map((tag) => (
            <span class="text-xs px-2 py-0.5 rounded-full bg-white/5 text-secondary">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-invert prose-cyan max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
